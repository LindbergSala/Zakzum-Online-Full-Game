# Local Docker PostgreSQL connection string for development.
# Copy this file to .env locally, then adjust values if your database differs.
DATABASE_URL="postgresql://zakzum:zakzum_dev_password@localhost:55432/zakzum_online_dev?schema=public"
DATABASE_URL_UNPOOLED="postgresql://zakzum:zakzum_dev_password@localhost:55432/zakzum_online_dev?schema=public"

# Local development session signing secret.
# Use a long random value in real environments.
AUTH_SESSION_SECRET="replace-with-a-long-random-session-secret"

# On Vercel with Neon, set DATABASE_URL, DATABASE_URL_UNPOOLED, and
# AUTH_SESSION_SECRET in the project environment.
#
# DATABASE_URL should be the pooled runtime URL, often DATABASE_URL or
# POSTGRES_PRISMA_URL from the Vercel Storage integration.
#
# DATABASE_URL_UNPOOLED should be the direct/non-pooling URL, often
# DATABASE_URL_UNPOOLED or POSTGRES_URL_NON_POOLING from the integration.
