{
  "name": "zakzum-online",
  "version": "0.1.0",
  "private": true,
  "description": "A DnD-inspired text-based RPG web game set in the world of Zakzum.",
  "scripts": {
    "dev": "next dev",
    "build": "prisma migrate deploy && prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v",
    "db:migrate": "prisma migrate dev",
    "db:validate": "prisma validate",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "bcryptjs": "3.0.3",
    "jose": "^6.2.3",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.9",
    "prisma": "6.19.3"
  }
}
